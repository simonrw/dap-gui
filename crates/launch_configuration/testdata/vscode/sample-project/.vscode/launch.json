{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "With Env Var",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "CUSTOM": "${env:DAP_TEST_CUSTOM_VAR}"
            }
        }
    ]
}
